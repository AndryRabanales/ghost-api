// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- MODELO CREADOR (Tu Cliente) ---
model Creator {
  id                     String    @id // Dashboard ID
  publicId               String    @unique
  name                   String?
  email                  String?   @unique
  password               String?
  createdAt              DateTime  @default(now())
  
  // Stripe Connect (CRÍTICO PARA COBRAR)
  stripeAccountId        String?   @unique
  stripeAccountOnboarded Boolean   @default(false)

  // Configuración de Negocio
  baseTipAmountCents     Int       @default(10000) // $100.00 MXN
  premiumContract        String?   @default("Respuesta garantizada.")
  topicPreference        String?   @default("Cualquier tema.")

  // Métricas Simples
  msgCountToday          Int       @default(0)
  dailyMsgLimit          Int       @default(30)
  msgCountLastReset      DateTime  @default(now())
  lastActive             DateTime?

  // Relaciones
  chats                  Chat[]
  links                  ProductLink[]
}

// --- MODELO CHAT (La Transacción) ---
model Chat {
  id          String        @id @default(uuid())
  creatorId   String
  anonToken   String        // Token para que el fan vea su chat
  anonAlias   String?
  createdAt   DateTime      @default(now())
  isOpened    Boolean       @default(false)
  anonReplied Boolean       @default(false)

  creator     Creator       @relation(fields: [creatorId], references: [id])
  messages    ChatMessage[]
}

// --- MODELO MENSAJE (El Producto) ---
model ChatMessage {
  id                 String   @id @default(uuid())
  chatId             String
  from               String   // "creator" o "anon"
  content            String
  createdAt          DateTime @default(now())
  seen               Boolean  @default(false)
  alias              String?
  
  // --- DINERO ---
  tipAmount          Float?
  tipPaymentIntentId String?  @unique
  tipStatus          String?  // 'PENDING', 'PROCESSING', 'FULFILLED'
  
  // --- IA ---
  priorityScore      Float?
  relevanceScore     Int?

  chat               Chat     @relation(fields: [chatId], references: [id])
}

// --- MODELO AUXILIAR (Links extra) ---
model ProductLink {
  id        String   @id @default(uuid())
  creatorId String
  title     String
  url       String
  createdAt DateTime @default(now())
  creator   Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
}

// --- 👇 NUEVO MODELO: CÓDIGOS DE INVITACIÓN (SOFT LAUNCH) 👇 ---
model InviteCode {
  id        String   @id @default(uuid())
  code      String   @unique
  isUsed    Boolean  @default(false)
  usedBy    String?  // Guardamos el email de quien lo usó
  createdAt DateTime @default(now())
}